{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{
        "name": "binaries/scanner-bridge",
        "sidecar": true,
        "args": ["--config", { "validator": ".*" }]
      }]
    },
    "shell:allow-spawn",
    "shell:allow-kill",
    "fs:default",
    { "identifier": "fs:allow-read", "allow": [{ "path": "$APPDATA/**" }] },
    { "identifier": "fs:allow-write", "allow": [{ "path": "$APPDATA/**" }] }
  ]
}
