{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Scanner Bridge",
  "version": "1.0.0",
  "identifier": "com.uniden.scanner-bridge",
  "build": {
    "beforeDevCommand": null,
    "beforeBuildCommand": "cd frontend && npm run build",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [{
      "title": "Scanner Bridge",
      "width": 1100,
      "height": 600,
      "minWidth": 1100,
      "minHeight": 600,
      "resizable": true,
      "center": true
    }],
    "security": {
      "csp": null,
      "assetProtocol": { "enable": true, "scope": ["**"] }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/scanner-bridge"],
    "macOS": {
      "entitlements": "./entitlements/Entitlements.plist",
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": { "open": true }
  }
}
