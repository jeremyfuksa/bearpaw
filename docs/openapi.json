      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "KeyRequest": {
        "properties": {
          "key": {
            "type": "string",
            "title": "Key"
          }
        },
        "type": "object",
        "required": [
          "key"
        ],
        "title": "KeyRequest"
      },
      "LiveStateModel": {
        "properties": {
          "timestamp": {
            "type": "number",
            "title": "Timestamp"
          },
          "frequency": {
            "type": "number",
            "title": "Frequency"
          },
          "modulation": {
            "type": "string",
            "title": "Modulation"
          },
          "squelch_open": {
            "type": "boolean",
