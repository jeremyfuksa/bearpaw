          },
          "lockout": {
            "type": "boolean",
            "title": "Lockout"
          },
          "priority": {
            "type": "boolean",
            "title": "Priority"
          },
          "tone_squelch": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
