                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Channel"
          },
          "volume": {
            "type": "integer",
            "title": "Volume"
          },
          "battery": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Battery"
          },
          "stale": {
            "type": "boolean",
            "title": "Stale",
            "default": false
          }
