{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Bearpaw",
  "version": "1.0.0",
  "identifier": "com.uniden.bearpaw",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bearpaw",
        "width": 1280,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/icon.png"
    ]
  }
}
