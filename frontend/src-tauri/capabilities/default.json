{
  "identifier": "default",
  "description": "Default capability set for Bearpaw desktop.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-ask",
    "dialog:allow-open",
    "fs:allow-write-file",
    "fs:allow-read-file",
    {
      "identifier": "fs:scope",
      "allow": ["$DOWNLOAD/*"]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://github.com/jeremyfuksa/bearpaw" },
        { "url": "https://github.com/jeremyfuksa/bearpaw/**" }
      ]
    }
  ]
}
